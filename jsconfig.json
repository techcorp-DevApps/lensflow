{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/components/ui/*": ["./src/types/ui-shim.d.ts"],
      "@/components/dashboard/*": ["./src/types/dashboard-shim.d.ts"],
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "src/types/**/*.d.ts",
    "server/**/*.js",
    "server/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/vite-plugins",
    "src/components/ui",
    "src/test",
    "src/**/__tests__/**",
    "server/__tests__",
    "e2e",
    "playwright-report",
    "test-results",
    "uploads"
  ]
}
