modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "GAMESTACK_JS"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lint"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "build"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "e2e"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "lint"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run lint"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run test:unit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "build"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "e2e"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run test:e2e"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
publicDir = "dist"
run = ["node", "./dist/index.cjs"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "3000"
VITE_API_BASE_URL = "/api"
ADMIN_EMAIL = "admin@lensflow.app"
